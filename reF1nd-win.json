{
  "log": {"disabled": false, "level": "info", "timestamp": true},
  "http_clients": [{"tag": "Direct"}],
  "experimental": {
    "urltest_unified_delay": true,
    "cache_file": {"enabled": true, "store_fakeip": true, "store_dns": true},
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://ghfast.top/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_http_client": "Direct"}
  },
  "providers": [{"type": "remote", "tag": "🌈", "url": "订阅链接"}],
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"},
      {"tag": "hosts", "type": "hosts", "predefined": {"dns.alidns.com": ["223.5.5.5", "223.6.6.6"], "doh.pub": ["1.12.12.12", "120.53.53.53"]}},
      {"tag": "alidns", "type": "https", "server": "dns.alidns.com", "domain_resolver": "hosts"},
      {"tag": "dnspod", "type": "https", "server": "doh.pub", "domain_resolver": "hosts"},
      {"tag": "public", "type": "group", "servers": ["alidns", "dnspod"]},
      {"tag": "google", "type": "https", "server": "8.8.8.8", "detour": "🐝 Proxy"},
      {"tag": "fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/15", "inet6_range": "fc00::/18"}
    ],
    "rules": [
      {"preferred_by": ["hosts"], "server": "hosts"},
      {"clash_mode": "direct", "server": "local"},
      {"rule_set": "private", "server": "local"},
      {"query_type": "HTTPS", "action": "reject"},
      {"clash_mode": "global", "server": "fakeip"},
      {"rule_set": "adblock", "action": "predefined", "rcode": "NXDOMAIN"},
      {"rule_set": ["me", "apple", "micro", "cn"], "server": "public"},
      {"query_type": ["A", "AAAA"], "action": "evaluate", "server": "public"},
      {"match_response": true, "rule_set": "cnip", "action": "respond"},
      {"query_type": ["A", "AAAA"], "server": "fakeip", "rewrite_ttl": 1}
    ],
    "final": "google",
    "optimistic": true,
    "reverse_mapping": true,
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {"tag": "mixed-in", "type": "mixed", "listen": "::", "listen_port": 7890, "set_system_proxy": false},
    {"tag": "tun-in", "type": "tun", "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"], "auto_route": true, "strict_route": true}
  ],
  "outbounds": [
    {"tag": "🐝 Proxy", "type": "selector", "use_all_providers": true, "outbounds": ["🚀 Urltest", "🍉 Balance"]},
    {"tag": "🚀 Urltest", "type": "urltest", "use_all_providers": true},
    {"tag": "🍉 Balance", "type": "loadbalance", "strategy": "consistent-hashing", "use_all_providers": true},
    {"tag": "🍓 Final", "type": "selector", "outbounds": ["🐝 Proxy", "🐸 Direct"]},
    {"tag": "GLOBAL", "type": "selector", "use_all_providers": true, "outbounds": ["🐝 Proxy", "🚀 Urltest"]},
    {"tag": "🐸 Direct", "type": "direct"},
    {"tag": "🌉 Bridge", "type": "bridge"}
  ],
  "route": {
    "final": "🍓 Final",
    "auto_detect_interface": true,
    "default_http_client": "Direct",
    "default_domain_match_strategy": "prefer_fqdn",
    "default_domain_resolver": {"server": "public"},
    "rules": [
      {"preferred_by": "🌉 Bridge", "outbound": "🌉 Bridge"},
      {"action": "sniff", "sniffer": ["tls", "http", "quic", "dns"]},
      {"type": "logical", "mode": "or", "rules": [{"port": 53}, {"protocol": "dns"}], "action": "hijack-dns"},
      {"ip_is_private": true, "outbound": "🐸 Direct"},
      {"type": "logical", "mode": "or", "rules": [{"port": 853}, {"protocol": ["quic", "stun"]}], "action": "reject", "no_drop": true},
      {"clash_mode": "direct", "outbound": "🐸 Direct"},
      {"clash_mode": "global", "outbound": "GLOBAL"},
      {"rule_set": "private", "outbound": "🐸 Direct"},
      {"rule_set": "me", "outbound": "🐸 Direct"},
      {"rule_set": "apple", "outbound": "🐸 Direct"},
      {"rule_set": "micro", "outbound": "🐸 Direct"},
      {"rule_set": "proxy", "outbound": "🐝 Proxy"},
      {"rule_set": "cn", "outbound": "🐸 Direct"},
      {"action": "resolve", "match_only": true},
      {"rule_set": "tgip", "outbound": "🐝 Proxy"},
      {"rule_set": "cnip", "outbound": "🐸 Direct"}
    ],
    "rule_set": [
      {"tag": ["me", "cn", "tgip", "cnip", "apple", "micro", "proxy", "private", "adblock"],
      "url": "https://ghfast.top/github.com/77160860/rule/raw/main/singbox/{tag}.srs",
      "type": "remote", "format": "binary"}]
  }
}
