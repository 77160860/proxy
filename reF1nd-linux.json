{
  "log": {"disabled": false, "level": "error", "timestamp": true},
  "http_clients": [{"tag": "Direct"}],
  "experimental": {
    "urltest_unified_delay": true,
    "cache_file": {"enabled": true, "store_fakeip": true, "store_dns": true},
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://ghfast.top/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_http_client": "Direct"
    }
  },
  "providers": [
    {
      "type": "remote",
      "tag": "🌈",
      "url": "订阅链接"
    }
  ],
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"},
      {"tag": "alidns", "type": "https", "server": "dns.alidns.com", "domain_resolver": "local"},
      {"tag": "dnspod", "type": "https", "server": "doh.pub", "domain_resolver": "local"},
      {"tag": "public", "type": "group", "servers": ["alidns", "dnspod"]},
      {"tag": "foreign", "type": "https", "server": "8.8.8.8", "detour": "🐝 Proxy"},
      {"tag": "fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/15", "inet6_range": "fc00::/18"}
    ],
    "rules": [
      {"clash_mode": "direct", "server": "local"},
      {"clash_mode": "global", "server": "fakeip"},
      {"query_type": "HTTPS", "action": "reject"},
      {"rule_set": "filter", "server": "local"},
      {"rule_set": "adblock", "action": "predefined", "rcode": "NXDOMAIN"},
      {"rule_set": ["me", "apple", "micro", "cn"], "server": "public"},
      {"query_type": ["A", "AAAA"], "server": "fakeip", "rewrite_ttl": 1}
    ],
    "final": "foreign",
    "strategy": "prefer_ipv4",
    "reverse_mapping": true,
    "optimistic": true
  },
  "inbounds": [
    {"tag": "tun-in", "type": "tun", "address": "172.18.0.1/30", "auto_route": true, "auto_redirect": true, "route_exclude_address_set": ["cnip", "pvip"]}
  ],
  "outbounds": [
    {"tag": "🐝 Proxy", "type": "selector", "use_all_providers": true, "outbounds": ["🚀 Urltest"]},
    {"tag": "🚀 Urltest", "type": "urltest", "use_all_providers": true},
    {"tag": "🍓 Final", "type": "selector", "outbounds": ["🐝 Proxy", "🐸 Direct"]},
    {"tag": "GLOBAL", "type": "selector", "use_all_providers": true, "outbounds": ["🐝 Proxy", "🚀 Urltest"]},
    {"tag": "🐸 Direct", "type": "direct"}
  ],
  "route": {
    "final": "🍓 Final",
    "auto_detect_interface": true,
    "default_http_client": "Direct",
    "default_domain_resolver": {"server": "public"},
    "default_domain_match_strategy": "prefer_fqdn",
    "rules": [
      {"action": "sniff"},
      {"type": "logical", "mode": "or", "rules": [{"protocol": "dns"}, {"port": 53}], "action": "hijack-dns"},
      {"ip_is_private": true, "outbound": "🐸 Direct"},
      {"type": "logical", "mode": "or", "rules": [{"port": 853}, {"network": "udp", "port": [8853]}, {"type": "logical", "mode": "and", "rules": [{"rule_set": "cnip", "invert": true}, {"type": "logical", "mode": "or", "rules": [{"network": "udp", "port": [443, 784]}, {"protocol": "stun"}]}]}], "action": "reject"},
      {"clash_mode": "direct", "outbound": "🐸 Direct"},
      {"clash_mode": "global", "outbound": "GLOBAL"},
      {"rule_set": "me", "outbound": "🐸 Direct"},
      {"rule_set": "apple", "outbound": "🐸 Direct"},
      {"rule_set": "micro", "outbound": "🐸 Direct"},
      {"rule_set": "proxy", "outbound": "🐝 Proxy"},
      {"rule_set": "cn", "outbound": "🐸 Direct"},
      {"action": "resolve", "match_only": true},
      {"rule_set": "tgip", "outbound": "🐝 Proxy"},
      {"rule_set": "cnip", "outbound": "🐸 Direct"}
    ],
    "rule_set": [
      {"tag": "me", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/me.srs"},
      {"tag": "cn", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/cn.srs"},
      {"tag": "apple", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/apple.srs"},
      {"tag": "micro", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/micro.srs"},
      {"tag": "proxy", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/proxy.srs"},
      {"tag": "tgip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/tgip.srs"},
      {"tag": "pvip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/pvip.srs"},
      {"tag": "cnip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/cnip.srs"},
      {"tag": "filter", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/filter.srs"},
      {"tag": "adblock", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/adblock.srs"}
    ]
  }
}
