{
  "log": {"disabled": false, "level": "error", "timestamp": true},
  "http_clients": [{"tag": "Direct"}],
  "experimental": {
    "urltest_unified_delay": true,
    "cache_file": {"enabled": true, "path": "/etc/momo/run/cache.db", "store_fakeip": true, "store_dns": true},
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "/etc/momo/run/ui",
      "external_ui_download_url": "https://gh-proxy.org/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_http_client": "Direct"
    }
  },
  "providers": [
    {
      "type": "remote",
      "tag": "🌈",
      "url": "订阅链接"
    }
  ],
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"},
      {"tag": "alidns", "type": "https", "server": "223.5.5.5"},
      {"tag": "google", "type": "https", "server": "8.8.8.8", "detour": "🐝 Proxy"},
      {"tag": "fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/15", "inet6_range": "fc00::/18"}
    ],
    "rules": [
      {"clash_mode": "direct", "server": "local"},
      {"clash_mode": "global", "server": "fakeip"},
      {"rule_set": "adblock", "action": "predefined", "rcode": "NXDOMAIN"},
      {"rule_set": ["me", "apple", "micro", "cn"], "server": "alidns"},
      {"query_type": ["A", "AAAA"], "action": "evaluate", "server": "alidns"},
      {"match_response": true, "rule_set": "cnip", "action": "respond"},
      {"query_type": ["A", "AAAA"], "server": "fakeip", "rewrite_ttl": 1}
    ],
    "final": "google",
    "optimistic": true,
    "reverse_mapping": true,
    "strategy": "prefer_ipv4"
  },
  "inbounds": [
    {"tag": "dns-in", "type": "direct", "listen": "::", "listen_port": 1053},
    {"tag": "tproxy-in", "type": "tproxy", "listen": "::", "listen_port": 7890},
    {"tag": "tun-in", "type": "tun", "interface_name": "momo", "address": ["172.18.0.1/30", "fdfe:dcba:9876::1/126"], "auto_route": true, "strict_route": true, "auto_redirect": true}
  ],
  "outbounds": [
    {"tag": "🐝 Proxy", "type": "selector", "use_all_providers": true, "outbounds": ["🚀 Urltest"]},
    {"tag": "🚀 Urltest", "type": "urltest", "use_all_providers": true},
    {"tag": "🍓 Final", "type": "selector", "outbounds": ["🐝 Proxy", "🐸 Direct"]},
    {"tag": "GLOBAL", "type": "selector", "use_all_providers": true, "outbounds": ["🐝 Proxy", "🚀 Urltest"]},
    {"tag": "🐸 Direct", "type": "direct"}
  ],
  "route": {
    "final": "🍓 Final",
    "auto_detect_interface": true,
    "default_http_client": "Direct",
    "default_domain_match_strategy": "prefer_fqdn",
    "default_domain_resolver": {"server": "alidns"},
    "rules": [
      {"action": "sniff"},
      {"inbound": "dns-in", "action": "hijack-dns"},
      {"ip_is_private": true, "outbound": "🐸 Direct"},
      {"clash_mode": "direct", "outbound": "🐸 Direct"},
      {"clash_mode": "global", "outbound": "GLOBAL"},
      {"rule_set": "me", "outbound": "🐸 Direct"},
      {"rule_set": "apple", "outbound": "🐸 Direct"},
      {"rule_set": "micro", "outbound": "🐸 Direct"},
      {"rule_set": "proxy", "outbound": "🐝 Proxy"},
      {"rule_set": "cn", "outbound": "🐸 Direct"},
      {"action": "resolve", "match_only": true},
      {"rule_set": "tgip", "outbound": "🐝 Proxy"},
      {"rule_set": "cnip", "outbound": "🐸 Direct"}
    ],
    "rule_set": [
      {"tag": "me", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/77160860/rule/raw/main/singbox/me.srs"},
      {"tag": "cnip", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geoip/cn.srs"},
      {"tag": "cn", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/cn.srs"},
      {"tag": "tgip", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geoip/telegram.srs"},
      {"tag": "apple", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/apple.srs"},
      {"tag": "micro", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/microsoft@cn.srs"},
      {"tag": "adblock", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/217heidai/adblockfilters/raw/main/rules/adblocksingboxlite.srs"},
      {"tag": "proxy", "type": "remote", "format": "binary", "url": "https://gh-proxy.org/github.com/MetaCubeX/meta-rules-dat/raw/sing/geo/geosite/geolocation-!cn.srs"}
    ]
  }
}
