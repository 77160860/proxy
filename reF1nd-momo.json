{
  "log": {"disabled": false, "level": "error", "timestamp": true},
  "experimental": {
    "urltest_unified_delay": true,
    "cache_file": {"enabled": true, "path": "/etc/momo/run/cache.db", "store_fakeip": true, "store_rdrc": true},
    "clash_api": {
      "external_controller": "0.0.0.0:9090",
      "external_ui": "/etc/momo/run/ui",
      "external_ui_download_url": "https://ghfast.top/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_download_detour": "🐸 Direct",
      "default_mode": "rule"
    }
  },
  "providers": [
    {
      "type": "remote",
      "tag": "airport",
      "url": "订阅链接",
      "download_detour": "🐸 Direct"
    }
  ],
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"},
      {"tag": "public", "type": "quic", "server": "dns.alidns.com", "domain_resolver": "local"},
      {"tag": "foreign", "type": "https", "server": "8.8.8.8", "detour": "🐝 Proxy"},
      {"tag": "fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/16"}
    ],
    "rules": [
      {"clash_mode": "direct", "server": "local"},
      {"clash_mode": "global", "server": "fakeip"},
      {"query_type": ["SVCB", "HTTPS"], "action": "predefined"},
      {"rule_set": "filter", "server": "local"},
      {"rule_set": "adblock", "action": "predefined"},
      {"rule_set": ["me", "apple", "microsoft", "cn"], "server": "public"},
      {"query_type": "A", "server": "fakeip", "rewrite_ttl": 1}
    ],
    "final": "foreign",
    "strategy": "ipv4_only",
    "reverse_mapping": true,
    "independent_cache": true,
    "round_robin_cache": true,
    "cache_capacity": 8000,
    "lazy_cache_ttl": 180000
  },
  "inbounds": [
    {"tag": "dns-in", "type": "direct", "listen": "::", "listen_port": 1053},
    {"tag": "redirect-in", "type": "redirect", "listen": "::", "listen_port": 7898},
    {"tag": "tproxy-in", "type": "tproxy", "listen": "::", "listen_port": 7899},
    {"tag": "tun-in", "type": "tun", "interface_name": "momo", "address": "168.18.0.1/30", "auto_route": false, "auto_redirect": false}
  ],
  "outbounds": [
    {"tag": "🐝 Proxy", "type": "selector", "use_all_providers": true, "outbounds": ["🚀 Urltest"]},
    {"tag": "🚀 Urltest", "type": "urltest", "use_all_providers": true},
    {"tag": "🍓 Final", "type": "selector", "outbounds": ["🐝 Proxy", "🐸 Direct"]},
    {"tag": "GLOBAL", "type": "selector", "use_all_providers": true, "outbounds": ["🐝 Proxy", "🚀 Urltest"]},
    {"tag": "🐸 Direct", "type": "direct"}
  ],
  "route": {
    "final": "🍓 Final",
    "auto_detect_interface": true,
    "default_domain_resolver": "public",
    "default_domain_match_strategy": "prefer_fqdn",
    "rules": [
      {"action": "sniff", "sniffer": ["http", "tls", "quic", "dns"]},
      {"inbound": "dns-in", "action": "hijack-dns"},
      {"ip_is_private": true, "outbound": "🐸 Direct"},
      {"clash_mode": "direct", "outbound": "🐸 Direct"},
      {"clash_mode": "global", "outbound": "GLOBAL"},
      {"rule_set": "me", "outbound": "🐸 Direct"},
      {"rule_set": "apple", "outbound": "🐸 Direct"},
      {"rule_set": "microsoft", "outbound": "🐸 Direct"},
      {"rule_set": "proxy", "outbound": "🐝 Proxy"},
      {"rule_set": "cn", "outbound": "🐸 Direct"},
      {"action": "resolve", "match_only": true},
      {"rule_set": "tgip", "outbound": "🐝 Proxy"},
      {"rule_set": "cnip", "outbound": "🐸 Direct"}
    ],
    "rule_set": [
      {"tag": "me", "type": "remote", "format": "source", "url": "https://fastly.jsdelivr.net/gh/77160860/proxy@main/me.json", "download_detour": "🐸 Direct"},
      {"tag": "filter", "type": "remote", "format": "source", "url": "https://fastly.jsdelivr.net/gh/77160860/proxy@main/filter.json", "download_detour": "🐸 Direct"},
      {"tag": "cn", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/cn.srs", "download_detour": "🐸 Direct"},
      {"tag": "apple", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/apple.srs", "download_detour": "🐸 Direct"},
      {"tag": "microsoft", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/microsoft@cn.srs", "download_detour": "🐸 Direct"},
      {"tag": "proxy", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geosite/geolocation-!cn.srs", "download_detour": "🐸 Direct"},
      {"tag": "cnip", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/cn.srs", "download_detour": "🐸 Direct"},
      {"tag": "tgip", "type": "remote", "format": "binary", "url": "https://fastly.jsdelivr.net/gh/MetaCubeX/meta-rules-dat@sing/geo/geoip/telegram.srs", "download_detour": "🐸 Direct"},
      {"tag": "adblock", "type": "remote", "format": "source", "url": "https://fastly.jsdelivr.net/gh/TG-Twilight/AWAvenue-Ads-Rule@main/Filters/AWAvenue-Ads-Rule-Singbox.json", "download_detour": "🐸 Direct"}
    ]
  }
}
