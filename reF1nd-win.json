{
  "log": {"disabled": false, "level": "error", "timestamp": true},
  "experimental": {
    "urltest_unified_delay": true,
    "cache_file": {"enabled": true, "store_fakeip": true, "store_dns": true},
    "clash_api": {
      "external_controller": "127.0.0.1:9090",
      "external_ui": "ui",
      "external_ui_download_url": "https://ghfast.top/github.com/Zephyruso/zashboard/releases/latest/download/dist-no-fonts.zip",
      "external_ui_download_detour": "🐸 Direct",
      "default_mode": "rule"
    }
  },
  "providers": [
    {
      "type": "remote",
      "tag": "🌈",
      "url": "订阅链接",
      "download_detour": "🐸 Direct"
    }
  ],
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"},
      {"tag": "hosts", "type": "hosts", "predefined": {"dns.alidns.com": ["223.5.5.5", "223.6.6.6"], "doh.pub": ["1.12.12.21", "120.53.53.53"]}},
      {"tag": "aldns", "type": "quic", "server": "dns.alidns.com", "domain_resolver": "hosts"},
      {"tag": "txdns", "type": "https", "server": "doh.pub", "domain_resolver": "hosts"},
      {"tag": "public", "type": "group", "servers": ["aldns", "txdns"]},
      {"tag": "foreign", "type": "https", "server": "8.8.8.8", "detour": "🐝 Proxy"},
      {"tag": "fakeip", "type": "fakeip", "inet4_range": "198.18.0.0/15"}
    ],
    "rules": [
      {"clash_mode": "direct", "server": "local"},
      {"clash_mode": "global", "server": "fakeip"},
      {"query_type": ["SVCB", "HTTPS"], "action": "predefined"},
      {"rule_set": "adblock", "action": "predefined", "rcode": "NXDOMAIN"},
      {"rule_set": "filter", "server": "local"},
      {"action": "evaluate", "server": "public"},
      {"match_response": true, "ip_accept_any": true, "invert": true, "action": "respond"},
      {"type": "logical", "mode": "or", "rules": [{"match_response": true, "ip_is_private": true}, {"match_response": true, "rule_set": "cnip"}], "action": "respond"},
      {"query_type": "A", "server": "fakeip", "rewrite_ttl": 1}
    ],
    "final": "foreign",
    "strategy": "ipv4_only",
    "reverse_mapping": true,
    "cache_capacity": 16000,
    "optimistic": {"enabled": true, "timeout": "7d"}
  },
  "inbounds": [
    {"tag": "mixed-in", "type": "mixed", "listen": "::", "listen_port": 7890, "set_system_proxy": false},
    {"tag": "tun-in", "type": "tun", "interface_name": "momo", "address": "172.18.0.1/30", "auto_route": true, "strict_route": true, "route_exclude_address_set": ["cnip", "pvip"]}
  ],
  "outbounds": [
    {"tag": "🐝 Proxy", "type": "selector", "use_all_providers": true, "outbounds": ["🚀 Urltest"]},
    {"tag": "🚀 Urltest", "type": "urltest", "use_all_providers": true},
    {"tag": "🍓 Final", "type": "selector", "outbounds": ["🐝 Proxy", "🐸 Direct"]},
    {"tag": "GLOBAL", "type": "selector", "use_all_providers": true, "outbounds": ["🐝 Proxy", "🚀 Urltest"]},
    {"tag": "🐸 Direct", "type": "direct"}
  ],
  "route": {
    "final": "🍓 Final",
    "auto_detect_interface": true,
    "default_domain_resolver": "public",
    "default_domain_match_strategy": "prefer_fqdn",
    "rules": [
      {"action": "sniff", "sniffer": ["http", "tls", "quic", "dns"]},
      {"protocol": "dns", "action": "hijack-dns"},
      {"protocol": "quic", "action": "reject"},
      {"ip_is_private": true, "outbound": "🐸 Direct"},
      {"clash_mode": "direct", "outbound": "🐸 Direct"},
      {"clash_mode": "global", "outbound": "GLOBAL"},
      {"rule_set": "me", "outbound": "🐸 Direct"},
      {"rule_set": "apple", "outbound": "🐸 Direct"},
      {"rule_set": "micro", "outbound": "🐸 Direct"},
      {"rule_set": "proxy", "outbound": "🐝 Proxy"},
      {"rule_set": "cn", "outbound": "🐸 Direct"},
      {"action": "resolve", "match_only": true},
      {"rule_set": "tgip", "outbound": "🐝 Proxy"},
      {"rule_set": "cnip", "outbound": "🐸 Direct"}
    ],
    "rule_set": [
      {"tag": "me", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/me.srs", "download_detour": "🐸 Direct"},
      {"tag": "cn", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/cn.srs", "download_detour": "🐸 Direct"},
      {"tag": "apple", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/apple.srs", "download_detour": "🐸 Direct"},
      {"tag": "micro", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/micro.srs", "download_detour": "🐸 Direct"},
      {"tag": "proxy", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/proxy.srs", "download_detour": "🐸 Direct"},
      {"tag": "tgip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/tgip.srs", "download_detour": "🐸 Direct"},
      {"tag": "pvip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/pvip.srs", "download_detour": "🐸 Direct"},
      {"tag": "cnip", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/cnip.srs", "download_detour": "🐸 Direct"},
      {"tag": "filter", "type": "remote", "format": "source", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/filter.json", "download_detour": "🐸 Direct"},
      {"tag": "adblock", "type": "remote", "format": "binary", "url": "https://ghfast.top/raw.githubusercontent.com/77160860/rule/main/singbox/adblock.srs", "download_detour": "🐸 Direct"}
    ]
  }
}
